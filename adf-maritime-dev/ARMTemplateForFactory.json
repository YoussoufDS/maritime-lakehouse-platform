{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-maritime-dev"
		},
		"ls_sqlserver_maritime_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlserver_maritime'"
		},
		"ls_adls_maritime_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_maritime'"
		},
		"ls_sqlserver_maritime_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "YOUSSOUF\\MICROSOFTSQLSERV"
		},
		"ls_sqlserver_maritime_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "MaritimeDB"
		},
		"ls_sqlserver_maritime_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "maritimeadmin"
		},
		"ls_adls_maritime_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmaritimedev.dfs.core.windows.net/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ls_sqlserver_maritime')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "SqlServer",
				"typeProperties": {
					"server": "[parameters('ls_sqlserver_maritime_properties_typeProperties_server')]",
					"database": "[parameters('ls_sqlserver_maritime_properties_typeProperties_database')]",
					"encrypt": "optional",
					"trustServerCertificate": true,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_sqlserver_maritime_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_sqlserver_maritime_password')]"
					}
				},
				"connectVia": {
					"referenceName": "SHIR-maritime-dev",
					"type": "IntegrationRuntimeReference"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/integrationRuntimes/SHIR-maritime-dev')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/SHIR-maritime-dev')]",
			"type": "Microsoft.DataFactory/factories/integrationRuntimes",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "SelfHosted",
				"typeProperties": {}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_adls_maritime')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ls_adls_maritime_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ls_adls_maritime_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_sqlserver_maritime')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_sqlserver_maritime",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"table_name": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "SqlServerTable",
				"schema": [],
				"typeProperties": {
					"schema": {
						"value": "@dataset().table_name",
						"type": "Expression"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_sqlserver_maritime')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_adls_parquet_landing')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_adls_maritime",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"folder_path": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": {
							"value": "@dataset().folder_path",
							"type": "Expression"
						},
						"fileSystem": "landing"
					},
					"compressionCodec": "snappy"
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_adls_maritime')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/pl_sqlserver_to_adls_maritime')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "ForEach",
						"type": "ForEach",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@json('[\n  {\"table\":\"vessels\",\"folder\":\"erp/fleet/vessels\"},\n  {\"table\":\"vessel_classes\",\"folder\":\"erp/fleet/vessel_classes\"},\n  {\"table\":\"ports\",\"folder\":\"erp/portops/ports\"},\n  {\"table\":\"terminals\",\"folder\":\"erp/portops/terminals\"},\n  {\"table\":\"berths\",\"folder\":\"erp/portops/berths\"},\n  {\"table\":\"voyages\",\"folder\":\"erp/navigation/voyages\"},\n  {\"table\":\"port_calls\",\"folder\":\"erp/navigation/port_calls\"},\n  {\"table\":\"cargo_types\",\"folder\":\"erp/cargo/cargo_types\"},\n  {\"table\":\"cargo_orders\",\"folder\":\"erp/cargo/cargo_orders\"},\n  {\"table\":\"cargo_manifests\",\"folder\":\"erp/cargo/cargo_manifests\"},\n  {\"table\":\"clients\",\"folder\":\"erp/commercial/clients\"},\n  {\"table\":\"contracts\",\"folder\":\"erp/commercial/contracts\"},\n  {\"table\":\"seafarers\",\"folder\":\"erp/crewing/seafarers\"},\n  {\"table\":\"crew_assignments\",\"folder\":\"erp/crewing/crew_assignments\"},\n  {\"table\":\"fuel_grades\",\"folder\":\"erp/fuelops/fuel_grades\"},\n  {\"table\":\"bunkering_events\",\"folder\":\"erp/fuelops/bunkering_events\"}\n]')",
								"type": "Expression"
							},
							"activities": [
								{
									"name": "Copy data",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "SqlServerSource",
											"sqlReaderQuery": {
												"value": "@concat('SELECT * FROM dbo.', item().table)",
												"type": "Expression"
											},
											"queryTimeout": "01:40:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "ParquetSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "ParquetWriteSettings"
											}
										},
										"enableStaging": false,
										"translator": {
											"type": "TabularTranslator",
											"typeConversion": true,
											"typeConversionSettings": {
												"allowDataTruncation": true,
												"treatBooleanAsNumber": false
											}
										}
									},
									"inputs": [
										{
											"referenceName": "ds_sqlserver_maritime",
											"type": "DatasetReference",
											"parameters": {
												"table_name": {
													"value": "@item().table",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_adls_parquet_landing",
											"type": "DatasetReference",
											"parameters": {
												"folder_path": {
													"value": "@item().folder",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_sqlserver_maritime')]",
				"[concat(variables('factoryId'), '/datasets/ds_adls_parquet_landing')]"
			]
		}
	]
}