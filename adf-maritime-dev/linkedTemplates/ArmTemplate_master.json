{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-maritime-dev"
		},
		"ls_sqlserver_maritime_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlserver_maritime'"
		},
		"ls_adls_maritime_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_maritime'"
		},
		"ls_sqlserver_maritime_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "YOUSSOUF\\MICROSOFTSQLSERV"
		},
		"ls_sqlserver_maritime_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "MaritimeDB"
		},
		"ls_sqlserver_maritime_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "maritimeadmin"
		},
		"ls_adls_maritime_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmaritimedev.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-maritime-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_maritime_accountKey": {
						"value": "[parameters('ls_adls_maritime_accountKey')]"
					},
					"ls_sqlserver_maritime_password": {
						"value": "[parameters('ls_sqlserver_maritime_password')]"
					},
					"ls_adls_maritime_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_maritime_properties_typeProperties_url')]"
					},
					"ls_sqlserver_maritime_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlserver_maritime_properties_typeProperties_server')]"
					},
					"ls_sqlserver_maritime_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlserver_maritime_properties_typeProperties_database')]"
					},
					"ls_sqlserver_maritime_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlserver_maritime_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}